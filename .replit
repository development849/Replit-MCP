modules = ["nodejs-20"]
run = "npm run start"

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "vm"
build = ["npm", "ci", "&&", "npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev"

[workflows.workflow.metadata]
outputType = "console"
