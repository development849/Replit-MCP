{
  "name": "replit-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for interacting with Replit workspaces",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "replit-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "replit",
    "ai",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
